    <string name="shizuku_help_step1_title">Download Shizuku</string>
    <string name="shizuku_help_step1_desc">Download Shizuku from Google Play or GitHub\n\n• Google Play: Search \"Shizuku\"\n• GitHub: github.com/RikkaApps/Shizuku</string>
    <string name="shizuku_help_step2_title">Start Shizuku</string>
    <string name="shizuku_help_step2_desc">Open Shizuku and choose a start method:\n\n• Wireless debugging (recommended): Android 11+, enable in Developer Options\n• Connect to PC: Start via ADB command</string>
    <string name="shizuku_help_step3_title">Authorize XiaoTaozi</string>
    <string name="shizuku_help_step3_desc">Find XiaoTaozi Autopilot in Shizuku App Management and grant permission</string>
    <string name="shizuku_help_step4_title">Start Using</string>
    <string name="shizuku_help_step4_desc">After authorization, return to XiaoTaozi app. The status card will show \"Shizuku Connected\"</string>
    <string name="overlay_why">Why is overlay permission needed?</string>
    <string name="overlay_reason">XiaoTaozi needs to display an overlay during task execution to:</string>
    <string name="overlay_feature1">Show current execution progress</string>
    <string name="overlay_feature2">Provide a stop button to interrupt tasks anytime</string>
    <string name="overlay_feature3">Display status information above other apps</string>
    <string name="overlay_how">How to enable?</string>
    <string name="overlay_how_desc">1. You will be prompted when executing a task\n2. Or go to: Settings > Apps > XiaoTaozi > Overlay\n3. Enable \"Allow display over other apps\"</string>
    <string name="overlay_privacy">Privacy &amp; Security</string>
    <string name="overlay_privacy_desc">The overlay is only shown during task execution and does not collect any personal information. It disappears automatically when the task completes.</string>
